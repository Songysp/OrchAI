[
  {
    "project_id": "sample-discord-project",
    "name": "Sample Discord Project",
    "description": "Sample multi-agent software project configured for Discord.",
    "status": "active",
    "chat_platform": "discord",
    "repo": {
      "url": "https://github.com/example/sample-discord-project",
      "default_branch": "main",
      "provider": "github"
    },
    "workspace_path": "workspaces/sample-discord-project",
    "execution_backend": "cli",
    "channel_bindings": {
      "ai-council": {
        "domain": "ai-council",
        "channel_id": "discord-ai-council",
        "thread_enabled": true,
        "metadata": {}
      },
      "ai-ops": {
        "domain": "ai-ops",
        "channel_id": "discord-ai-ops",
        "thread_enabled": true,
        "metadata": {}
      },
      "user-control": {
        "domain": "user-control",
        "channel_id": "discord-user-control",
        "thread_enabled": true,
        "metadata": {}
      }
    },
    "agent_mapping": {
      "representative": {
        "role": "representative",
        "provider": "claude",
        "model": "claude-sonnet",
        "system_prompt": null,
        "options": {}
      },
      "planner": {
        "role": "planner",
        "provider": "gemini",
        "model": "gemini-pro",
        "system_prompt": null,
        "options": {}
      },
      "scout": {
        "role": "scout",
        "provider": "gemini",
        "model": "gemini-pro",
        "system_prompt": null,
        "options": {}
      },
      "builder": {
        "role": "builder",
        "provider": "codex",
        "model": "codex-latest",
        "system_prompt": null,
        "options": {}
      },
      "critic": {
        "role": "critic",
        "provider": "claude",
        "model": "claude-sonnet",
        "system_prompt": null,
        "options": {}
      },
      "tester": {
        "role": "tester",
        "provider": "gemini",
        "model": "gemini-pro",
        "system_prompt": null,
        "options": {}
      }
    },
    "commands": {
      "plan": "python -m pytest -q",
      "build": "docker compose build",
      "test": "pytest",
      "lint": "python -m compileall .",
      "fix": "pytest -x",
      "setup": null
    },
    "rules": [
      {
        "rule_id": "require-auth-approval",
        "condition": "auth",
        "action": "require_approval",
        "metadata": {}
      },
      {
        "rule_id": "require-db-approval",
        "condition": "schema",
        "action": "require_approval",
        "metadata": {}
      },
      {
        "rule_id": "require-delete-approval",
        "condition": "delete",
        "action": "require_approval",
        "metadata": {}
      }
    ],
    "metadata": {
      "discord": {
        "intents_profile": "guild_messages",
        "reply_mode": "thread_or_channel"
      }
    }
  },
